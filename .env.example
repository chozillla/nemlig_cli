NEMLIG_USER=your@email.com
NEMLIG_PASS=yourpassword

# AI Provider — set one of: azure, openai, anthropic, mistral, groq,
#   together, deepseek, xai, fireworks, openrouter, ollama, lmstudio, custom
# AI_PROVIDER=azure

# --- Azure OpenAI ---
# AZURE_API_KEY=your-azure-api-key
# AZURE_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_DEPLOYMENT=gpt-4o

# --- OpenAI ---
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_MODEL=gpt-4o

# --- Anthropic (Claude) ---
# ANTHROPIC_API_KEY=sk-ant-your-key
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# --- Mistral ---
# MISTRAL_API_KEY=your-mistral-key
# MISTRAL_MODEL=mistral-large-latest

# --- Groq ---
# GROQ_API_KEY=gsk_your-groq-key
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Together AI ---
# TOGETHER_API_KEY=your-together-key
# TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# --- DeepSeek ---
# DEEPSEEK_API_KEY=your-deepseek-key
# DEEPSEEK_MODEL=deepseek-chat

# --- xAI (Grok) ---
# XAI_API_KEY=your-xai-key
# XAI_MODEL=grok-3

# --- Fireworks AI ---
# FIREWORKS_API_KEY=your-fireworks-key
# FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct

# --- OpenRouter ---
# OPENROUTER_API_KEY=your-openrouter-key
# OPENROUTER_MODEL=openai/gpt-4o

# --- Ollama (local) ---
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2

# --- LM Studio (local) ---
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LMSTUDIO_MODEL=default

# --- Custom OpenAI-compatible endpoint ---
# CUSTOM_BASE_URL=https://your-provider.com/v1
# CUSTOM_API_KEY=your-key
# CUSTOM_MODEL=your-model
